G_DM = 10*np.log10(G_DM_lin) ##dB

F_DM_lin = 1+(4/((S_LD*Gopt_DM_lin*Rpd)**2)  + \
    (2*q*Pin2_lin*RL)/(S_LD**2*Gopt_DM_lin*Rpd*k*T)+ \
    (RIN_lin*Pin2_lin**2*RL)/(S_LD**2*k*T))

NF_DM = 10*np.log10(F_DM_lin) ##dB


