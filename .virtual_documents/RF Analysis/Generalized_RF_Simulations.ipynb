        (16*Vpi**2)/(np.pi**2 * Pin_lin**2 * Gopt_EM_lin **2 * Rpd **2 * RL **2) + \
        (16*q*Vpi**2)/(np.pi**2 * Pin_lin * Gopt_EM_lin * Rpd * RL*k*T) + \
        (4*Vpi**2*RIN_sweep_lin[i])/(np.pi**2*RL*k*T)
    NF_EM[i,:] = 10*np.log10(NF_EM_lin[i,:]) ##dB

    
    
