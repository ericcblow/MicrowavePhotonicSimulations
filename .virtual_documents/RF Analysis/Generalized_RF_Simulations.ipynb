    NF_EM_lin_LNA[z,:]  = LNA_NF_lin_sweep[z]+(NF_EM_lin-1)/LNA_G_lin
    NF_EM_LNA[z,:]  = 10*np.log10(NF_EM_lin_LNA[z,:]) ##dB

    # SFDR

    SFDR_EM_LNA[z,:]  = SFDR_3  + (NF_EM - NF_EM_LNA[z,:] )-LNA_G



